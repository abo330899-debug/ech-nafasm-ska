modules = ["nodejs-24", "python-3.11"]
run = ["pnpm", "start"]

[deployment]
  router = "application"
deploymentTarget = "gce"
  run = ["pnpm", "start"]

[deployment.env]
  PORT = "8080"
  NODE_ENV = "production"

[deployment.build]
  args = ["sh", "-c", "pnpm install && pnpm --filter @workspace/nafsam run build && pnpm --filter @workspace/api-server run build"]

[deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

[workflows]
  runButton = "Project"

[agent]
  stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

