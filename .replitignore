# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make the process of publishing faster.

# Development tooling and state (not needed at build or runtime)
.local/
.git/
.cache/
.config/
.agents/

# Backup — 2.65 GB, no build or runtime use
project-backup.zip

# Dev-session artifacts — not needed in production
attached_assets/
vercel/
osv-scanner.toml
Pasted-*.txt

# Loose media files uploaded at workspace root (private/ folder is kept separately)
*.mp4
*.MP4
*.MOV
*.mov
*.avi
*.mkv

# Node packages in the initial snapshot.
# The build commands reinstall them; the artifact.toml cleanup removes them afterwards.
node_modules/
**/node_modules/

# Dev-only artifact (canvas mockup sandbox)
artifacts/mockup-sandbox/
